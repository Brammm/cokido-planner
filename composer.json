{
    "name": "brammm/cokido-planner",
    "description": "Planning tool for Cokido out-of-school care",
    "type": "project",
    "authors": [
        {
            "name": "Bram Van der Sype",
            "email": "bram.vandersype@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "CokidoPlanner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.5",
        "brammm/smart": "*@dev",
        "crell/envmapper": "^1.1",
        "cuyz/valinor": "^2.4",
        "doctrine/persistence": "^4.2",
        "patchlevel/event-sourcing": "^3.19",
        "php-standard-library/str": "^6.2"
    },
    "repositories": [
        {
            "type": "path",
            "url": "./packages/smart"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1"
    }
}
